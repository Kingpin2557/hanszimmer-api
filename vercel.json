{
  "version": 2,
  "builds": [
    {
      "src": "/server/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/routes.ts",
          "server/routes/**",
          "server/data/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server/app.ts",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, HEAD, OPTIONS, POST, PUT, DELETE, PATCH",
        "Access-Control-Allow-Headers": "Content-Type, Authorization, Range, Content-Range, Accept-Encoding",
        "Access-Control-Expose-Headers": "Content-Range, Content-Length, Accept-Ranges",
        "Access-Control-Max-Age": "86400"
      }
    }
  ]
}
