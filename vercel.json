{
  "version": 2,
  "builds": [
    {
      "src": "server/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**/*.ts",
          "server/data/**/*",
          "node_modules/ffmpeg-static/**/*"
        ]
      }
    }
  ],
  "functions": {
    "server/app.ts": {
      "memory": 3009,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/app.ts"
    }
  ]
}
