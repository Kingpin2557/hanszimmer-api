{
  "version": 2,
  "builds": [
    {
      "src": "server/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**/*.ts",
          "server/data/**/*"
        ],
        "maxDuration": 60,
        "memory": 3009
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/app.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/warm",
      "schedule": "0 4 * * *"
    }
  ]
}
