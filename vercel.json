{
  "version": 2,
  "builds": [
    {
      "src": "server/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**/*.ts",
          "server/data/**/*",
          "node_modules/ffmpeg-static/**/*"
        ],
        "maxDuration": 60,
        "memory": 3009
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/app.ts"
    }
  ]
}
